# ============================================================
#  NEXUS BOT 2 — Environment Variables
#  Copy this file to .env and fill in your values
# ============================================================

# ─── Discord Bot ─────────────────────────────────────────────
TOKEN=your_discord_bot_token_here
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_bot_client_id_here
DISCORD_CLIENT_ID=your_discord_oauth_client_id_here
DISCORD_CLIENT_SECRET=your_discord_oauth_client_secret_here

# ─── Server ───────────────────────────────────────────────────
PORT=8000
BASE_URL=https://your-app-name.koyeb.app
REDIRECT_URI=https://your-app-name.koyeb.app/dashboard/login
KOYEB_PUBLIC_URL=https://your-app-name.koyeb.app

# ─── Database (TiDB) ─────────────────────────────────────────
TIDB_HOST=gateway01.eu-central-1.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=your_tidb_user
TIDB_PASSWORD=your_tidb_password
TIDB_DB=test

# ─── Session ─────────────────────────────────────────────────
SESSION_SECRET=change_this_to_a_long_random_string_at_least_32_chars

# ─── AI ──────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─── PayPal Payments ─────────────────────────────────────────
# Get credentials from: https://developer.paypal.com/dashboard/
# Set PAYPAL_MODE=live for production, sandbox for testing
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_MODE=sandbox
# Optional: Set this to verify PayPal webhook signatures
# Get from: PayPal Developer Dashboard > Webhooks
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id_here

# ─── Crypto Wallet Addresses ─────────────────────────────────
# Set ONLY the coins you want to accept. Leave blank to disable.
# Each coin uses a DIFFERENT address for security.
CRYPTO_WALLET_BTC=your_bitcoin_address_here
CRYPTO_WALLET_ETH=your_ethereum_address_here
CRYPTO_WALLET_LTC=your_litecoin_address_here
CRYPTO_WALLET_USDT_TRC20=your_tron_usdt_address_here
CRYPTO_WALLET_USDT_ERC20=your_ethereum_usdt_address_here
CRYPTO_WALLET_BNB=your_bnb_bsc_address_here
CRYPTO_WALLET_SOL=your_solana_address_here

# ─── Blockchain API Keys (optional, improves crypto verification) ──
# Free tier is sufficient for most use cases
# Etherscan: https://etherscan.io/apis
ETHERSCAN_API_KEY=your_etherscan_api_key_here
# BSCScan: https://bscscan.com/apis
BSCSCAN_API_KEY=your_bscscan_api_key_here

# ─── Premium Trial ────────────────────────────────────────────
# Number of days for the free trial (default: 3)
PREMIUM_TRIAL_DAYS=3

# ─── Data Storage ────────────────────────────────────────────
DATA_DIR=/app/data
